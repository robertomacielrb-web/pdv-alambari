{
  "entities": {
    "Table": {
      "title": "Table",
      "description": "A table in the establishment",
      "type": "object",
      "properties": {
        "number": { "type": "number", "description": "The table number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["number"]
    },
    "Product": {
      "title": "Product",
      "description": "A product available for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Product price" },
        "category": { "type": "string", "description": "Product category" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A sales order (balcao, mesa, or fiado)",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["balcao", "mesa", "fiado"], "description": "Type of order" },
        "status": { "type": "string", "enum": ["open", "closed"], "description": "Status of the order" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            },
            "required": ["productId", "name", "price", "quantity"]
          }
        },
        "total": { "type": "number", "description": "Total amount of the order" },
        "paymentMethod": { "type": "string", "enum": ["dinheiro", "cartao", "pix"], "description": "Payment method used" },
        "createdAt": { "type": "string", "format": "date-time" },
        "closedAt": { "type": "string", "format": "date-time" },
        "password": { "type": "number", "description": "Password/ticket number for balcao" },
        "tableNumber": { "type": "number", "description": "Table number for mesa" },
        "customerName": { "type": "string", "description": "Customer name for fiado" },
        "customerPhone": { "type": "string", "description": "WhatsApp phone number of the customer" },
        "cashierId": { "type": "string", "description": "ID of the cashier session" }
      },
      "required": ["type", "status", "items", "total", "createdAt"]
    },
    "CashierSession": {
      "title": "Cashier Session",
      "description": "A cashier session (open/close)",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["open", "closed"] },
        "openedAt": { "type": "string", "format": "date-time" },
        "closedAt": { "type": "string", "format": "date-time" },
        "initialBalance": { "type": "number" },
        "finalBalance": { "type": "number" },
        "totalSales": { "type": "number" }
      },
      "required": ["status", "openedAt", "initialBalance", "totalSales"]
    },
    "Bill": {
      "title": "Bill",
      "description": "An account payable (conta a pagar)",
      "type": "object",
      "properties": {
        "description": { "type": "string", "description": "Description of the bill" },
        "amount": { "type": "number", "description": "Amount to pay" },
        "dueDate": { "type": "string", "format": "date-time", "description": "Due date" },
        "status": { "type": "string", "enum": ["pending", "paid"], "description": "Payment status" },
        "paymentDate": { "type": "string", "format": "date-time", "description": "Payment date" },
        "category": { "type": "string", "description": "Bill category" },
        "notes": { "type": "string", "description": "Additional notes" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["description", "amount", "dueDate", "status", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products inventory"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Sales orders"
    },
    "/cashierSessions/{sessionId}": {
      "schema": { "$ref": "#/entities/CashierSession" },
      "description": "Cashier sessions"
    },
    "/bills/{billId}": {
      "schema": { "$ref": "#/entities/Bill" },
      "description": "Accounts payable (contas a pagar)"
    },
    "/tables/{tableId}": {
      "schema": { "$ref": "#/entities/Table" },
      "description": "Establishment seating tables"
    }
  }
}
